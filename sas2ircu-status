#!/bin/bash

# Configuration
BINARYPATH="/usr/sbin/sas2ircu"

# 1. Executable check
[[ ! -x "$BINARYPATH" ]] && {
    echo "Error: $BINARYPATH not found or not executable."
    exit 1
}

# Variables
NAGIOS_MODE=0
EXIT_CODE=0
N_GOOD_ARRAY=0
N_BAD_ARRAY=0
N_GOOD_DISK=0
N_BAD_DISK=0

# 2. Argument Parsing
case "$1" in
    --nagios) NAGIOS_MODE=1 ;;
    "")       NAGIOS_MODE=0 ;;
    *)        echo "Usage: ${0##*/} [--nagios]"; exit 1 ;;
esac

status_print() {
    (( ! NAGIOS_MODE )) && printf -- "$@"
}

# 3. Controller Discovery with Hardware ID Fallback
CTRL_LIST=$($BINARYPATH LIST | awk '/^[ ]*[0-9]+/ {print $1":"$2":"$4}')

if [[ ! "$CTRL_LIST" ]]; then
    (( NAGIOS_MODE )) && echo "RAID CRITICAL - No controllers found" && exit 2
    echo "No controllers found."
    exit 0
fi

status_print "-- Controller informations --\n-- ID | Model | FW | BIOS\n"

for CTRL_ENTRY in $CTRL_LIST; do
    CTRL_ID=$(echo "$CTRL_ENTRY" | cut -d: -f1)
    CTRL_TYPE=$(echo "$CTRL_ENTRY" | cut -d: -f2)
    CTRL_DEVID=$(echo "$CTRL_ENTRY" | cut -d: -f3)

    DISPLAY_OUT=$($BINARYPATH "$CTRL_ID" DISPLAY 2>/dev/null)

    # 4. Progress Tracking & Integer Conversion
    # Pulls e.g., "68.56%" -> chops to "68%"
    RAW_PCT=$($BINARYPATH "$CTRL_ID" STATUS 2>/dev/null | awk -F': ' '/Percentage complete/ {print $2}' | tr -d '[:space:]')
    PROGRESS_PCT=${RAW_PCT%.*}
    [[ "$PROGRESS_PCT" ]] && PROGRESS_PCT="${PROGRESS_PCT}%"

    FW_VER=$(awk -F': ' '/Firmware version/ {print $2}' <<< "$DISPLAY_OUT" | tr -d '[:space:]')
    BIOS_VER=$(awk -F': ' '/BIOS version/ {print $2}' <<< "$DISPLAY_OUT" | tr -d '[:space:]')

    if [[ "$CTRL_TYPE" == "UNKNOWN" ]]; then
        case "$CTRL_DEVID" in
            "72h") CTRL_TYPE="SAS2008" ;;
            "97h") CTRL_TYPE="SAS2308" ;;
            *)     CTRL_TYPE="LSI-SAS2" ;;
        esac
    fi

    status_print "c%s | %s | %s | %s\n" "$CTRL_ID" "$CTRL_TYPE" "$FW_VER" "$BIOS_VER"

    # --- Process Arrays ---
    ARRAY_DATA=$(awk '
        /^IR volume/ { id++; found_size=0; printf "\n"id"|" }
        /Status of volume/ { split($0,a,": "); val=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", val); printf val"|" }
        /RAID level/ { split($0,a,": "); val=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", val); printf val"|" }
        /Size \(in MB\)/ {
            if (!found_size) {
                split($0,a,": "); val=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", val);
                printf int(val/1000 + 0.5)"G|"; found_size=1
            }
        }
    ' <<< "$DISPLAY_OUT")

    status_print "\n-- Arrays informations --\n-- ID | Type | Size | Status\n"

    VOL_IDX=0
    while IFS="|" read -r _RAW_ID STATUS TYPE SIZE; do
        [[ ! "$STATUS" ]] && continue

        if [[ "$STATUS" == "Okay (OKY)" || "$STATUS" == "Inactive, Okay (OKY)" ]]; then
            (( N_GOOD_ARRAY++ ))
            FINAL_STATUS="$STATUS"
        else
            (( N_BAD_ARRAY++ ))
            if [[ "$STATUS" =~ (Degraded|Failed|Missing) ]]; then
                EXIT_CODE=2
                [[ "$PROGRESS_PCT" ]] && FINAL_STATUS="$STATUS ($PROGRESS_PCT)" || FINAL_STATUS="$STATUS"
            elif [[ $EXIT_CODE -lt 2 ]]; then
                EXIT_CODE=3
                [[ "$PROGRESS_PCT" ]] && FINAL_STATUS="$STATUS ($PROGRESS_PCT)" || FINAL_STATUS="$STATUS"
            fi
        fi
        status_print "c%su%s | %s | %s | %s\n" "$CTRL_ID" "$VOL_IDX" "$TYPE" "$SIZE" "$FINAL_STATUS"
        (( VOL_IDX++ ))
    done <<< "$ARRAY_DATA"

    # --- Process Disks ---
    DISK_DATA=$(awk '
        BEGIN { printf "\n" }
        /^Device is a Hard disk/ { if (count > 0) printf "\n"; count++; model="UNK"; state="UNK"; serial="UNK"; pred=0 }
        /State/ { split($0,a,": "); state=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", state) }
        /Model Number/ { split($0,a,": "); model=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", model) }
        /Serial No/ { split($0,a,": "); serial=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", serial) }
        /Predictive Failure Count/ { split($0,a,": "); pred=a[2]; gsub(/^[ \t]+|[ \t]+$/, "", pred) }
        /GUID/ { printf "%s|%s|%s|%s\n", state, model, serial, pred }
    ' <<< "$DISPLAY_OUT")

    status_print "\n-- Disks informations\n-- ID | Model | Status\n"

    DISK_IDX=0
    while IFS="|" read -r STATE MODEL SERIAL PREDICTIVE; do
        [[ ! "$STATE" || "$STATE" == "UNK" ]] && continue

        P_COUNT=$(tr -d '[:space:]' <<< "$PREDICTIVE")
        P_COUNT=${P_COUNT:-0}

        if [[ "$STATE" == "Optimal (OPT)" ]] && (( ! P_COUNT )); then
            (( N_GOOD_DISK++ ))
            DISPLAY_STATE="$STATE"
        else
            (( N_BAD_DISK++ ))
            if (( P_COUNT )); then
                EXIT_CODE=2
                DISPLAY_STATE="PREDICTIVE FAILURE ($P_COUNT)"
            elif [[ "$STATE" == "Rebuilding (RBLD)" ]]; then
                [[ $EXIT_CODE -lt 2 ]] && EXIT_CODE=3
                [[ "$PROGRESS_PCT" ]] && DISPLAY_STATE="$STATE ($PROGRESS_PCT)" || DISPLAY_STATE="$STATE"
            else
                EXIT_CODE=2
                DISPLAY_STATE="$STATE"
            fi
        fi

        status_print "c%su0p%s | %s (%s) | %s\n" "$CTRL_ID" "$DISK_IDX" "$MODEL" "$SERIAL" "$DISPLAY_STATE"
        (( DISK_IDX++ ))
    done <<< "$DISK_DATA"
done

# --- Final Summary ---
MSG="Arrays: OK:$N_GOOD_ARRAY Bad:$N_BAD_ARRAY - Disks: OK:$N_GOOD_DISK Bad:$N_BAD_DISK"

if (( NAGIOS_MODE )); then
    case $EXIT_CODE in
        0) echo "RAID OK - $MSG" ;;
        3) echo "RAID WARNING (Sync/Rebuild) - $MSG" ;;
        *) echo "RAID ERROR - $MSG" ;;
    esac
else
    (( EXIT_CODE )) && echo -e "\nThere is at least one disk/array in a NOT OPTIMAL state."
fi

exit "$EXIT_CODE"
